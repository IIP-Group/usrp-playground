# ── GHCR / Deployment ──
GHCR_OWNER=raresbares
IMAGE_TAG=latest
ENTRYPOINT_PORT=8000

# ── Database ──
POSTGRES_USER=usrp
POSTGRES_PASSWORD=usrp_secret
POSTGRES_DB=usrp_bench
DATABASE_URL=postgresql://usrp:usrp_secret@db:5432/usrp_bench

# ── Auth ──
DEFAULT_AUTH_TOKEN=default-bench-token-2024
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_SESSION_SECRET=ZUFALLSSTRING_32+_ZEICHEN
TOKEN_SECRET=NOCH_EIN_ZUFALLSSTRING

# ── USRP Device Type ──
USRP_DEVICE_TYPE=b200

# ── USRP / Radio ──
CARRIER_FREQUENCY_HZ=2400000000
SAMPLE_RATE_HZ=16000000
BANDWIDTH_HZ=8000000
TX_GAIN_DB=30
RX_GAIN_DB=30
CHANNEL_SNR_DB=20
ANTENNA_TX=TX/RX
ANTENNA_RX=RX2
TX_CHANNEL=0
RX_CHANNEL=0

# ── USRP Mode ──
USE_REAL_USRP=true

# ── ZMQ Daemon Addresses (as seen from worker container) ──
TX_DAEMON_HOST=host.docker.internal
TX_DAEMON_PORT=5557
RX_DAEMON_HOST=host.docker.internal
RX_DAEMON_PORT=5555

# ── Signal Exchange ──
SIGNAL_DIR=/data/signals
SIGNAL_DIR_HOST=/home/rares/USRP-Benchmark-System/data/signals

# ── TX/RX Timing ──
TX_RX_DELAY_DIFF=0.1
INITIAL_DELAY=1.0

# ── Duty Cycle ──
DUTY_CYCLE_MAX_PERCENT=10
DUTY_CYCLE_WINDOW_SEC=60

# ── Listen Before Talk (LBT) ──
LBT_ENABLED=true
LBT_THRESHOLD_DBFS=-50
LBT_SENSE_SAMPLES=200000
LBT_MAX_RETRIES=10
LBT_BACKOFF_SEC=1.0

# ── Guard Times ──
BEGIN_GUARD_MIN_SEC=0.1
BEGIN_GUARD_MAX_SEC=0.1
END_GUARD_MIN_SEC=0.1
END_GUARD_MAX_SEC=0.1

# ── Limits ──
MAX_UPLOAD_MB=200
MAX_SAMPLES=2500000
MAX_WS_CONNECTIONS=100
MAX_PENDING_TASKS=200
TASK_TTL_HOURS=24
PUBLIC_HTTP_PORT=80

# ── Per-device-type overrides (start-daemons.sh picks automatically) ──
USRP_TX_ADDR_B200=serial=3485538
USRP_RX_ADDR_B200=serial=3485539
MASTER_CLOCK_RATE_B200=32000000

USRP_TX_ADDR_X4XX=192.168.10.2
USRP_RX_ADDR_X4XX=192.168.20.2
MASTER_CLOCK_RATE_X4XX=250000000
