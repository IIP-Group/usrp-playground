# ── GHCR / Deployment ──
GHCR_OWNER=raresbares
IMAGE_TAG=latest

# Public nginx port — was der Student erreicht (HTTP)
PUBLIC_HTTP_PORT=80

# ── Admin Panel Credentials ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploy
# 32+ random bytes für die Session-Signatur
ADMIN_SESSION_SECRET=change-me-long-random-string
# Secret für die Token-Generierung (Studenten-Tokens)
TOKEN_SECRET=change-me-long-random-string-too

# ── Database ──
POSTGRES_USER=usrp
POSTGRES_PASSWORD=usrp_secret
POSTGRES_DB=usrp_bench
DATABASE_URL=postgresql://usrp:usrp_secret@db:5432/usrp_bench

# ── Student Auth (default token, falls USER_ID gebunden werden soll) ──
DEFAULT_AUTH_TOKEN=default-bench-token-2024

# ── USRP / Radio (Defaults — 2.4 GHz SRD, see SRD_* block at bottom) ──
# CARRIER, BANDWIDTH and TX_POWER are LOCKED in the admin UI to keep the
# server compliant with RIR1008-11 (10 dBm EIRP). Change here, not in DB.
CARRIER_FREQUENCY_HZ=2475000000
BANDWIDTH_HZ=15625000
# TX_POWER_DBM = calibrated absolute output power at the USRP SMA. With a
# 3 dBi antenna and 0.5 dB cable, 7.5 dBm SMA gives ≈10 dBm EIRP — exactly
# at the legal limit and the highest "useful" value.
TX_POWER_DBM=7.5
# Sample rate is derived: SAMPLE_RATE_HZ = BANDWIDTH_HZ × SAMPLE_RATE_BANDWIDTH_RATIO.
# The admin UI exposes a 1..5 slider for the ratio. Default ratio = 2.
SAMPLE_RATE_BANDWIDTH_RATIO=2
SAMPLE_RATE_HZ=31250000
# Legacy fallback if the calibrated power API is not available.
TX_GAIN_DB=20
RX_GAIN_DB=30
ANTENNA_TX=TX/RX0
ANTENNA_RX=RX1
TX_CHANNEL=0
RX_CHANNEL=0

# ── ZMQ Daemon Addresses (Worker → Daemons auf Host) ──
TX_DAEMON_HOST=host.docker.internal
TX_DAEMON_PORT=5557
RX_DAEMON_HOST=host.docker.internal
RX_DAEMON_PORT=5555

# ── USRP Devices (für die Daemons) ──
USRP_TX_ADDR=192.168.10.2
USRP_RX_ADDR=192.168.20.2
MASTER_CLOCK_RATE=250000000

# ── Signal Exchange ──
SIGNAL_DIR=/data/signals
SIGNAL_DIR_HOST=/home/rares/USRP-Benchmark-System/data/signals

# ── TX/RX Timing (Random Guard — uniform zwischen min und max) ──
INITIAL_DELAY=1.0
BEGIN_GUARD_MIN_SEC=0.1
BEGIN_GUARD_MAX_SEC=0.1
END_GUARD_MIN_SEC=0.1
END_GUARD_MAX_SEC=0.1

# ── Duty Cycle ──
DUTY_CYCLE_MAX_PERCENT=10
DUTY_CYCLE_WINDOW_SEC=60

# ── Listen Before Talk (LBT) ──
LBT_ENABLED=true
LBT_THRESHOLD_DBFS=-50
LBT_SENSE_SAMPLES=200000
LBT_MAX_RETRIES=10
LBT_BACKOFF_SEC=1.0

# ── Limits ──
MAX_UPLOAD_MB=200
MAX_SAMPLES=2500000
MAX_WS_CONNECTIONS=100
MAX_PENDING_TASKS=200
TASK_TTL_HOURS=24


# ── 2.4 GHz SRD operating envelope (RIR1008-11 / EN 300 440) ────────────────
# Non-specific SRD: 2400-2483.5 MHz, 10 mW EIRP max, license-exempt, no duty
# cycle, no LBT required. These values feed the Settings info banner.
SRD_BAND_LABEL=2.4 GHz SRD — RIR1008-11 (Non-specific SRD)
SRD_BAND_F_MIN_HZ=2400000000
SRD_BAND_F_MAX_HZ=2483500000
SRD_MAX_EIRP_DBM=10
SRD_NOTE=License-exempt, NIB/NPB. Stay within 2400-2483.5 MHz, ≤10 mW EIRP. No duty cycle, no LBT. EIRP = USRP_TX_Output - cable_loss + antenna_gain.
