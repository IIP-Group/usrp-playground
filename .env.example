# ── GHCR / Deployment ──
GHCR_OWNER=raresbares
IMAGE_TAG=latest

# Public nginx port — was der Student erreicht (HTTP)
PUBLIC_HTTP_PORT=80

# ── Admin Panel Credentials ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploy
# 32+ random bytes für die Session-Signatur
ADMIN_SESSION_SECRET=change-me-long-random-string
# Secret für die Token-Generierung (Studenten-Tokens)
TOKEN_SECRET=change-me-long-random-string-too

# ── Database ──
POSTGRES_USER=usrp
POSTGRES_PASSWORD=usrp_secret
POSTGRES_DB=usrp_bench
DATABASE_URL=postgresql://usrp:usrp_secret@db:5432/usrp_bench

# ── Student Auth (default token, falls USER_ID gebunden werden soll) ──
DEFAULT_AUTH_TOKEN=default-bench-token-2024

# ── USRP / Radio (Defaults — via Admin-Panel überschreibbar) ──
CARRIER_FREQUENCY_HZ=2400000000
SAMPLE_RATE_HZ=25000000
BANDWIDTH_HZ=25000000
TX_GAIN_DB=30
RX_GAIN_DB=30
ANTENNA_TX=TX/RX0
ANTENNA_RX=RX1
TX_CHANNEL=0
RX_CHANNEL=0

# ── ZMQ Daemon Addresses (Worker → Daemons auf Host) ──
TX_DAEMON_HOST=host.docker.internal
TX_DAEMON_PORT=5557
RX_DAEMON_HOST=host.docker.internal
RX_DAEMON_PORT=5555

# ── USRP Devices (für die Daemons) ──
USRP_TX_ADDR=192.168.10.2
USRP_RX_ADDR=192.168.20.2
MASTER_CLOCK_RATE=250000000

# ── Signal Exchange ──
SIGNAL_DIR=/data/signals
SIGNAL_DIR_HOST=/home/rares/USRP-Benchmark-System/data/signals

# ── TX/RX Timing (Random Guard — uniform zwischen min und max) ──
INITIAL_DELAY=1.0
BEGIN_GUARD_MIN_SEC=0.1
BEGIN_GUARD_MAX_SEC=0.1
END_GUARD_MIN_SEC=0.1
END_GUARD_MAX_SEC=0.1

# ── Duty Cycle ──
DUTY_CYCLE_MAX_PERCENT=10
DUTY_CYCLE_WINDOW_SEC=60

# ── Listen Before Talk (LBT) ──
LBT_ENABLED=true
LBT_THRESHOLD_DBFS=-50
LBT_SENSE_SAMPLES=200000
LBT_MAX_RETRIES=10
LBT_BACKOFF_SEC=1.0

# ── Limits ──
MAX_UPLOAD_MB=200
MAX_SAMPLES=2500000
MAX_WS_CONNECTIONS=100
MAX_PENDING_TASKS=200
TASK_TTL_HOURS=24

# ── Band Presets (CEPT/ETSI REC 70-03 limits, license-free SRD) ─────────────
# These are picked up by the Settings page "Band Preset" widget so the admin
# can apply the regulatory envelope of each band with one click.
# An empty value (e.g. BAND_433_DUTY_CYCLE_PERCENT=) means "not regulated" and
# is rendered as "—" in the UI.

# Each preset locks CARRIER_HZ, SAMPLE_RATE_HZ (≡ BANDWIDTH_HZ) and TX_GAIN_DB
# to band-appropriate values. Duty cycle and LBT are also applied. Setting
# DUTY_CYCLE_PERCENT to empty means "not regulated" → "—" in UI.

# 433 MHz band — 10 mW ERP, no duty cycle
BAND_433_LABEL=433 MHz — 10 mW ERP, no duty cycle
BAND_433_CARRIER_HZ=433920000
BAND_433_SAMPLE_RATE_HZ=976562
BAND_433_TX_GAIN_DB=20
BAND_433_MAX_EIRP_DBM=10
BAND_433_DUTY_CYCLE_PERCENT=
BAND_433_LBT_REQUIRED=false
BAND_433_NOTE=433.05–434.79 MHz, 10 mW ERP. Highest legal continuous-TX option in this band without licence.

# 868 MHz band — 869.4–869.65 MHz subband: 500 mW ERP, 10 % duty cycle
BAND_868_LABEL=868 MHz — 500 mW ERP, 10 % duty cycle
BAND_868_CARRIER_HZ=869525000
BAND_868_SAMPLE_RATE_HZ=244140
BAND_868_TX_GAIN_DB=30
BAND_868_MAX_EIRP_DBM=27
BAND_868_DUTY_CYCLE_PERCENT=10
BAND_868_LBT_REQUIRED=false
BAND_868_NOTE=Use 869.4–869.65 MHz subband. Other 868 MHz subbands are tighter (25 mW / 0.1–1 %).

# 2.4 GHz band — 100 mW EIRP, no duty cycle
BAND_2400_LABEL=2.4 GHz — 100 mW EIRP, no duty cycle
BAND_2400_CARRIER_HZ=2400000000
BAND_2400_SAMPLE_RATE_HZ=31250000
BAND_2400_TX_GAIN_DB=30
BAND_2400_MAX_EIRP_DBM=20
BAND_2400_DUTY_CYCLE_PERCENT=
BAND_2400_LBT_REQUIRED=false
BAND_2400_NOTE=2400–2483.5 MHz wideband. Spread-spectrum or LBT recommended for ETSI EN 300 328 compliance at higher power.

# 5.8 GHz band — 25 mW EIRP, no duty cycle
BAND_5800_LABEL=5.8 GHz — 25 mW EIRP, no duty cycle
BAND_5800_CARRIER_HZ=5800000000
BAND_5800_SAMPLE_RATE_HZ=31250000
BAND_5800_TX_GAIN_DB=25
BAND_5800_MAX_EIRP_DBM=14
BAND_5800_DUTY_CYCLE_PERCENT=
BAND_5800_LBT_REQUIRED=false
BAND_5800_NOTE=5725–5875 MHz non-specific SRD. Power-limited but no duty cycle.
